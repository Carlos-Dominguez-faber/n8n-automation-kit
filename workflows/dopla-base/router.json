    {
      "parameters": {
        "jsCode": "const record = $('3b. Extraer registro').first().json;\n\n// Extraer brand del array Supabase\nconst brandRaw = $('4b. Buscar Marca').first().json;\nconst marcaArr = Array.isArray(brandRaw) ? brandRaw : [brandRaw];\nconst marca = marcaArr[0] || {};\nconst brand_id = marca.id || null;\n\n// Extraer style del array Supabase\nconst styleRaw = $('4c. Buscar Estilo').first().json;\nconst styleArr = Array.isArray(styleRaw) ? styleRaw : [styleRaw];\nconst estilo = styleArr[0] || {};\nconst style_id = estilo.id || null;\n\n// Extraer avatar del array Supabase (solo para Reel UGC)\nconst avatarRaw = $('4d. Buscar Avatar').first().json;\nconst avatarArr = Array.isArray(avatarRaw) ? avatarRaw : [avatarRaw];\nconst avatar = avatarArr[0] || null;\nconst avatar_uuid = avatar?.id || null;\n\nconst tipo = record.tipo_a_crear || '';\n\nif (!marca.id) throw new Error('No se encontro marca default para este tenant');\nif (!estilo.id) throw new Error('No se encontro estilo para tipo \"' + tipo + '\"');\nif (tipo === 'Reel UGC' && !avatar) throw new Error('No se encontro avatar HeyGen para Reel UGC');\n\n// Parsear colors_jsonb si viene como string\nlet colores = '';\ntry { colores = typeof marca.colors_jsonb === 'string' ? marca.colors_jsonb : JSON.stringify(marca.colors_jsonb || {}); } catch (e) {}\n\nconst brand = {\n  nombre: marca.name || '',\n  handle_ig: marca.handle_ig || '',\n  tono: marca.tone || '',\n  audiencia: marca.audience || '',\n  colores,\n  estilo_visual: marca.visual_style || '',\n  reglas_lenguaje: marca.language_rules || '',\n  color_fondo_ugc: marca.ugc_bg_color || '#0D1B2A',\n  voz_elevenlabs: marca.elevenlabs_voice || 'Roger',\n  subtitulos: marca.subtitles_config || '',\n  logo_url: marca.logo_url || ''\n};\n\nconst style_prompts = {\n  prompt_sistema: estilo.system_prompt || '',\n  prompt_usuario: estilo.user_prompt || '',\n  nombre_estilo: estilo.name || '',\n  tipo_contenido: estilo.content_type || tipo\n};\n\nconst systemPrompt = 'Eres el estratega de contenido de ' + (brand.nombre || 'la marca') + '.\\n\\nBRAND VOICE:\\n- Tono: ' + (brand.tono || 'Profesional y directo') + '\\n- Audiencia: ' + (brand.audiencia || 'Profesionales') + '\\n- Colores: ' + (brand.colores || '') + '\\n\\nSIEMPRE responde en formato JSON valido con EXACTAMENTE los campos: mi_hook, mi_caption, prompt_generacion.';\n\nconst userPrompt = 'Basandote en este post de la competencia, genera contenido adaptado a la marca ' + (brand.nombre || '') + '.\\n\\nPOST DE REFERENCIA:\\nCuenta: ' + (record.source_account || 'N/A') + '\\nTipo original: ' + (record.source_type || 'N/A') + '\\nHook original: ' + (record.hook_original || 'N/A') + '\\nCaption original: ' + (record.original_caption || 'N/A') + '\\nAnalisis: ' + (record.analysis || 'N/A') + '\\nTranscripcion: ' + (record.transcription || 'N/A') + '\\n\\nTIPO A CREAR: ' + tipo + '\\n\\nGenera SOLO un JSON valido con EXACTAMENTE esta estructura:\\n{\\n  \"mi_hook\": \"Hook adaptado a la marca.\",\\n  \"mi_caption\": \"Caption completo para Instagram.\",\\n  \"prompt_generacion\": \"Direccion visual resumida en ingles.\"\\n}';\n\nconst requestBody = JSON.stringify({\n  model: 'openai/gpt-4.1-mini',\n  response_format: { type: 'json_object' },\n  messages: [\n    { role: 'system', content: systemPrompt },\n    { role: 'user', content: userPrompt }\n  ]\n});\n\nreturn [{\n  json: {\n    ...record,\n    brand,\n    style_prompts,\n    avatar_id: avatar?.heygen_avatar_id || null,\n    avatar_nombre: avatar?.name || null,\n    brand_id,\n    style_id,\n    avatar_uuid,\n    requestBody\n  }\n}];"
      },
