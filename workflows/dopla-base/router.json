      "parameters": {
        "jsCode": "const aiRaw = $input.first().json;\nconst original = $('4e. Componer datos').first().json;\n\nlet mi_hook = '';\nlet mi_caption = '';\nlet prompt_gen = '';\n\ntry {\n  const content = aiRaw.choices?.[0]?.message?.content || '';\n  const parsed = JSON.parse(content);\n  mi_hook = parsed.mi_hook || '';\n  mi_caption = parsed.mi_caption || '';\n  prompt_gen = parsed.prompt_generacion || '';\n} catch (e) {\n  mi_hook = 'Error al generar';\n  mi_caption = aiRaw.choices?.[0]?.message?.content || '';\n  prompt_gen = '';\n}\n\nreturn [{\n  json: {\n    contentId: original.id,\n    tenantId: original.tenant_id,\n    tipo: original.tipo_a_crear,\n    num_slides: original.num_slides || 5,\n    mi_hook,\n    mi_caption,\n    prompt_gen,\n    hook_original: original.hook_original || '',\n    caption_original: original.original_caption || '',\n    transcripcion: original.transcription || '',\n    analisis: original.analysis || '',\n    brand: original.brand,\n    style_prompts: original.style_prompts,\n    avatar_id: original.avatar_id || null,\n    avatar_nombre: original.avatar_nombre || null,\n    brand_id: original.brand_id || null,\n    style_id: original.style_id || null,\n    avatar_uuid: original.avatar_uuid || null\n  }\n}];"
      },
